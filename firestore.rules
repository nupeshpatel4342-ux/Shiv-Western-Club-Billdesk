rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - email: string (required) - User email
    //   - displayName: string - User display name
    //   - photoURL: string - User photo URL
    //   - role: string (required) - 'admin' or 'staff'
    //   - createdAt: number (required) - Creation timestamp
    //
    // Collection: bills
    // Document ID: {billId}
    // Fields:
    //   - id: string (required) - Bill ID
    //   - total: number (required) - Total amount
    //   - balance: number (required) - Pending amount
    //   - paymentStatus: string (required) - 'PAID' or 'UNPAID'
    //   - createdBy: string (required) - UID of creator
    //   - timestamp: number (required) - Creation timestamp
    //   - customer: string
    //   - mobile: string
    //   - items: list
    //
    // Collection: settings
    // Document ID: global
    // Fields:
    //   - shopName: string
    //   - ownerName: string
    //   - address: string
    //   - phone: string
    //   - email: string
    //   - currency: string
    //   - upiQrCode: string (base64)
    //   - logo: string (base64)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "Nupeshpatel4342@gmail.com" && request.auth.token.email_verified == true));
    }

    function isStaff() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff' || isAdmin());
    }

    // Validate User Profile
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid.size() < 128 &&
             data.email is string && data.email.size() < 256 &&
             data.role in ['admin', 'staff'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 128)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 1024));
    }

    // Validate Bill
    function isValidBill(data) {
      return data.keys().hasAll(['id', 'total', 'paymentStatus', 'createdBy', 'timestamp']) &&
             data.id is string && data.id.size() < 128 &&
             data.total is number && data.total >= 0 &&
             data.paymentStatus in ['PAID', 'UNPAID'] &&
             data.createdBy is string && data.createdBy.size() < 128 &&
             data.timestamp is number &&
             (!('customer' in data) || (data.customer is string && data.customer.size() < 256)) &&
             (!('mobile' in data) || (data.mobile is string && data.mobile.size() < 20)) &&
             (!('items' in data) || (data.items is list && data.items.size() < 100));
    }

    // Validate Settings
    function isValidSettings(data) {
      return (!('shopName' in data) || (data.shopName is string && data.shopName.size() < 256)) &&
             (!('ownerName' in data) || (data.ownerName is string && data.ownerName.size() < 256)) &&
             (!('address' in data) || (data.address is string && data.address.size() < 1024)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() < 20)) &&
             (!('email' in data) || (data.email is string && data.email.size() < 256)) &&
             (!('currency' in data) || (data.currency is string && data.currency.size() < 10));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Only the user can create/update their own profile, but they can't make themselves admin unless they are already admin
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'staff' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    // Bills Collection
    match /bills/{billId} {
      allow read: if isAuthenticated();
      allow create: if isStaff() && isValidBill(request.resource.data) && request.resource.data.createdBy == request.auth.uid;
      allow update: if isStaff() && isValidBill(request.resource.data) && 
                      (resource.data.createdBy == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Settings Collection
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }
    
    // Test collection for connection check
    match /test/connection {
      allow read: if true;
    }
  }
}
